# ============================================================
# Coal Pile Measurement Backend - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ============================================================
# Core Settings
# ============================================================
DATABASE_URL=postgresql://user:password@localhost/coal_db
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=your-secret-key-here-change-in-production

# ============================================================
# NodeODM (OpenDroneMap REST API)
# ============================================================
# Start NodeODM with Docker:
#   docker run -p 3000:3000 opendronemap/nodeodm
#
# Or use WebODM Lightning cloud (set to their API endpoint):
#   NODE_ODM_URL=https://webodm.net
NODE_ODM_URL=http://localhost:3000

# NodeODM Quality Settings
# Feature quality: ultra, high, medium, low, lowest
# Higher = better feature detection but slower processing
NODE_ODM_FEATURE_QUALITY=ultra

# Point cloud quality: ultra, high, medium, low, lowest
# Higher = denser point cloud and better mesh detail
NODE_ODM_PC_QUALITY=ultra

# Mesh size: number of triangles in the final mesh
# Higher = more detailed mesh but larger file size
# Recommended: 200000 (fast), 500000 (balanced), 1000000 (high detail)
NODE_ODM_MESH_SIZE=500000

# Minimum features to detect per image
# Higher = better matching but slower
NODE_ODM_MIN_NUM_FEATURES=10000

# Number of neighbor images to match against
# Higher = better reconstruction but slower
NODE_ODM_MATCHER_NEIGHBORS=12

# Mesh octree depth (9-14)
# Higher = finer mesh detail
NODE_ODM_MESH_OCTREE_DEPTH=11

# ============================================================
# Legacy Meshroom & Processing Paths (no longer used)
# ============================================================
# MESHROOM_PATH=/usr/local/bin/meshroom_batch
CLOUDCOMPARE_PATH=/usr/local/bin/CloudCompare
UPLOAD_DIR=/tmp/coal_uploads
RESULTS_DIR=/tmp/coal_results

# ============================================================
# GPU Acceleration (Requirement 1)
# ============================================================
# Enable/disable GPU acceleration for Meshroom processing
GPU_ENABLED=true

# Maximum fraction of GPU memory to use (0.0-1.0)
# Falls back to CPU if usage exceeds this threshold (Requirement 1.3)
GPU_MEMORY_LIMIT_PERCENT=0.9

# Maximum concurrent GPU-accelerated jobs (Requirement 12.2)
MAX_CONCURRENT_GPU_JOBS=2

# Maximum concurrent CPU-only jobs (Requirement 12.3)
MAX_CONCURRENT_CPU_JOBS=4

# ============================================================
# Timeout Management (Requirement 4)
# ============================================================
# Base seconds per image for timeout calculation
# Formula: timeout = TIMEOUT_BASE_SECONDS_PER_IMAGE * image_count
TIMEOUT_BASE_SECONDS_PER_IMAGE=60

# Minimum timeout in seconds (Requirement 4.4)
MIN_TIMEOUT_SECONDS=600

# Maximum timeout in seconds (Requirement 4.4)
MAX_TIMEOUT_SECONDS=7200

# Legacy timeout (kept for backward compatibility)
MESHROOM_TIMEOUT=3600

# ============================================================
# Caching (Requirement 7)
# ============================================================
# Directory for intermediate result cache
CACHE_DIR=/tmp/meshroom_cache

# Maximum cache size in GB (Requirement 7.6)
CACHE_MAX_SIZE_GB=100

# Cache expiration in days (Requirement 7.5)
CACHE_EXPIRATION_DAYS=7

# ============================================================
# Input Validation (Requirement 11)
# ============================================================
# Minimum number of images required for reconstruction
MIN_IMAGE_COUNT=8

# Minimum image resolution (width x height)
MIN_IMAGE_RESOLUTION_WIDTH=640
MIN_IMAGE_RESOLUTION_HEIGHT=480

# Laplacian variance threshold for blur detection (Requirement 11.3)
# Images below this threshold are flagged as blurry
SHARPNESS_THRESHOLD=100.0

# ============================================================
# Quality Thresholds (Requirement 5)
# ============================================================
# Quality score below this value triggers low-quality flag (Requirement 5.5)
LOW_QUALITY_SCORE_THRESHOLD=50

# ============================================================
# Mesh Optimization (Requirement 6)
# ============================================================
# Maximum volume change allowed after optimization (percent)
MESH_VOLUME_TOLERANCE_PERCENT=2.0

# Maximum hole size to fill automatically (percent of surface area)
MAX_HOLE_SIZE_PERCENT=5.0

# Maximum time for mesh optimization as percent of reconstruction time
OPTIMIZATION_TIME_LIMIT_PERCENT=10.0

# ============================================================
# Retry Configuration (Requirement 14)
# ============================================================
# Maximum number of automatic retry attempts
MAX_RETRY_ATTEMPTS=2

# Delay between retry attempts in seconds
RETRY_DELAY_SECONDS=30

# ============================================================
# Coal Measurement
# ============================================================
# Coal density in kg/m³ for weight estimation
COAL_DENSITY=1300.0

# Frame extraction interval for video input (seconds)
FRAME_EXTRACTION_INTERVAL=1.0
